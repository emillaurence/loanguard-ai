# Anthropic API
ANTHROPIC_API_KEY=                # Your Anthropic API key from console.anthropic.com

# Neo4j AuraDB
NEO4J_URI=                        # e.g. neo4j+s://<id>.databases.neo4j.io
NEO4J_USERNAME=                   # Default: neo4j
NEO4J_PASSWORD=                   # AuraDB instance password
